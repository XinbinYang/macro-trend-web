# Data Source API Keys
# Copy this file to .env.local and fill in your keys

# FRED API (US Macro Data)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=935f73b129321e28d71641c3f6d7b1a3

# Alpha Vantage (Global Stocks) - Optional
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# OpenExchangeRates (FX Data) - Optional
# Get your key at: https://openexchangerates.org/signup/free
OPENEXCHANGERATES_APP_ID=

# Tushare Token (A-Share Data) - Optional
# Get your token at: https://tushare.pro/register
TUSHARE_TOKEN=

# OpenRouter API Key (for AI analysis)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
