{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-yields",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/daily-cn-rates",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/cron/monthly-cn-policy",
      "schedule": "0 3 20-22 * *"
    },
    {
      "path": "/api/cron/daily-us-policy",
      "schedule": "0 10 * * 1-5"
    }
  ]
}
