{
  "version": "1.0",
  "description": "Macro Framework Configuration - Indicators, Thresholds, and Main/Aux Selection",
  "dimensions": {
    "growth": {
      "name": "增长",
      "emoji": "📈",
      "indicators": {
        "us": {
          "main": "us_ism_services_pmi",
          "aux": ["us_ism_manufacturing_pmi", "us_unemployment_rate"],
          "thresholds": {
            "strong": 52,
            "weak": 48,
            "higherIsBetter": true
          }
        },
        "cn": {
          "main": "cn_pmi_mfg",
          "aux": ["cn_pmi_services"],
          "thresholds": {
            "strong": 50.5,
            "weak": 49,
            "higherIsBetter": true
          }
        }
      }
    },
    "inflation": {
      "name": "通胀",
      "emoji": "🔥",
      "indicators": {
        "us": {
          "main": "us_core_pce_yoy",
          "aux": ["us_cpi_yoy", "us_core_cpi_yoy"],
          "thresholds": {
            "strong": 2.5,
            "weak": 4.0,
            "higherIsBetter": false
          }
        },
        "cn": {
          "main": "cn_cpi_yoy",
          "aux": ["cn_ppi_yoy"],
          "thresholds": {
            "strong": 2.5,
            "weak": 0.0,
            "higherIsBetter": true
          }
        }
      }
    },
    "policy": {
      "name": "政策",
      "emoji": "🏛️",
      "indicators": {
        "us": {
          "main": "us_sofr",
          "aux": ["us_fed_funds_rate"],
          "thresholds": {
            "strong": 3.0,
            "weak": 5.5,
            "higherIsBetter": false
          }
        },
        "cn": {
          "main": "cn_lpr_1y",
          "aux": ["cn_mlf_rate", "cn_slf_rate"],
          "thresholds": {
            "strong": 3.0,
            "weak": 4.0,
            "higherIsBetter": false
          }
        }
      }
    },
    "liquidity": {
      "name": "流动性",
      "emoji": "💧",
      "indicators": {
        "us": {
          "main": "us_10y_yield",
          "aux": ["us_2y_yield"],
          "thresholds": {
            "strong": 4.0,
            "weak": 4.7,
            "higherIsBetter": false
          }
        },
        "cn": {
          "main": "cn_m2_yoy",
          "aux": ["cn_shibor_overnight"],
          "thresholds": {
            "strong": 9.5,
            "weak": 7.5,
            "higherIsBetter": true
          }
        }
      }
    }
  },
