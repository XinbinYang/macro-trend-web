{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-yields",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/monthly-cn-policy",
      "schedule": "0 2 21 * *"
    }
  ]
}
